# Copy to terraform.tfvars and fill in real values. Never commit terraform.tfvars.

aws_region          = "ap-south-1"
cluster_name        = "self-healing-cluster"
cluster_version     = "1.32"
environment         = "dev"
system_node_type    = "t3.medium"
workload_node_type  = "t3.large"
system_node_count   = 2
workload_node_count = 2
enable_ha_nat       = false

# Terraform state bucket — create this S3 bucket manually before `terraform init`.
state_bucket = "REPLACE-WITH-YOUR-TF-STATE-BUCKET"

# Secrets — pushed to AWS Secrets Manager by the iam module.
# Default provider is Anthropic Claude — store the key as a K8s secret (see README Step 6).
# gemini_api_key is only needed if you plan to use the Gemini ModelConfig alternative.
gemini_api_key    = ""  # optional — leave blank if using Anthropic (Claude)
slack_webhook_url = ""  # optional, e.g. "https://hooks.slack.com/services/..."

tags = {
  Project   = "self-healing-k8s-kagent"
  ManagedBy = "terraform"
  Owner     = "your-name"
}
