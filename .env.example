# Copy this file to .env and fill in real values for local development.
# Never commit a populated .env file.

# Gemini API
GEMINI_API_KEY=replace-with-real-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Kubernetes / kubeconfig (local dev only — in-cluster uses ServiceAccount)
KUBECONFIG=/home/youruser/.kube/config

# Agent behavior
DRY_RUN=true
CONFIDENCE_THRESHOLD=0.75
MAX_REPLICAS=10
DAILY_REQUEST_LIMIT=200
MEMORY_DB_PATH=/tmp/kagent-memory.db
AUDIT_LOG_PATH=/tmp/kagent-audit.jsonl
LOG_LEVEL=INFO

# AWS (only used when running in-cluster on EKS)
AWS_REGION=us-east-1
SECRETS_MANAGER_REGION=us-east-1
GEMINI_API_KEY_SECRET=kagent/gemini-api-key
SLACK_WEBHOOK_SECRET=kagent/slack-webhook

# Optional notifications
SLACK_WEBHOOK_URL=
